rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // 1. PRODUCTS: Public read, Admin-only modification
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. USERS: Self-read/write, Admin-read (all)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 3. ORDERS: Self-read, Admin-full access
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 4. FAILED SYNCS: Admin-only audit logs
    match /failed_syncs/{syncId} {
      allow read, write: if isAdmin();
    }

    // 5. IDEMPOTENCY KEYS: User-only access
    match /idempotency_keys/{keyId} {
      allow read, write: if isAuthenticated() && keyId.startsWith(request.auth.uid);
    }
  }
}
